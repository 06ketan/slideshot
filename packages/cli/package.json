{
  "name": "slideshot",
  "version": "2.6.0",
  "description": "Convert HTML slides to high-res PNG, WebP, PDF, and PPTX — CLI + library",
  "type": "module",
  "license": "MIT",
  "author": "Ketan Chavan",
  "bin": {
    "slideshot": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "html-to-image",
    "slides",
    "carousel",
    "puppeteer",
    "screenshot",
    "pdf",
    "pptx",
    "powerpoint",
    "cli",
    "linkedin-carousel",
    "slideshot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/06ketan/slideshot",
    "directory": "packages/cli"
  },
  "homepage": "https://slideshot.vercel.app",
  "bugs": "https://github.com/06ketan/slideshot/issues",
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js && rm -rf ./prompts && cp -r ../../prompts ./prompts",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
