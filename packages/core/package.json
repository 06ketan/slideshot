{
  "name": "html-to-slides-core",
  "version": "1.0.0",
  "description": "Core Puppeteer engine for rendering HTML slides to PNG, WebP, and PDF",
  "type": "module",
  "license": "MIT",
  "author": "Ketan Chavan",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "html-to-image",
    "slides",
    "carousel",
    "puppeteer",
    "screenshot",
    "pdf",
    "png",
    "webp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ketan-chavan/html-to-slides",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ketan-chavan/html-to-slides#readme",
  "bugs": "https://github.com/ketan-chavan/html-to-slides/issues",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "puppeteer": "^24.39.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
